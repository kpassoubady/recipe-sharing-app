@page "/"

<PageTitle>Recipe Sharing App</PageTitle>

<div class="text-center mt-5">
    <h1 class="display-4">🍳 Recipe Sharing App</h1>
    <p class="lead">Discover, Share, and Cook Amazing Recipes</p>
    
    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">📖 Browse Recipes</h5>
                    <p class="card-text">Explore our collection of delicious recipes from various cuisines</p>
                    <a href="recipes" class="btn btn-primary">View Recipes</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🔍 Search by Ingredients</h5>
                    <p class="card-text">Find recipes based on ingredients you have at home</p>
                    <a href="recipes" class="btn btn-primary">Search Now</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">⭐ Rate & Review</h5>
                    <p class="card-text">Share your cooking experience with others</p>
                    <a href="recipes" class="btn btn-primary">Get Started</a>
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-5">
        <h3>Features</h3>
        <ul class="list-unstyled">
            <li>✅ 10+ Curated Recipes with Full Instructions</li>
            <li>✅ Nutritional Information for Every Recipe</li>
            <li>✅ Difficulty Levels and Cook Time</li>
            <li>✅ User Ratings and Reviews</li>
            <li>✅ Recipe Categories and Tags</li>
            <li>✅ Search Recipes by Ingredients</li>
        </ul>
    </div>
</div>
